{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist",
      "!node_modules"
    ]
  },
  "formatter": {
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "noAmbiguousAnchorText": "off",
        "noSvgWithoutTitle": "off"
      },
      "security": {
        "noBlankTarget": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    },
    "nursery": {
      "useSortedClasses": "error"
    }
  }
}