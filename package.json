{
  "name": "matrikkel-dokument-generering",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && bun run build:css",
    "build:css": "tailwindcss -i src/document.css -o dist/document-styles.css --minify",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check . --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "preview": "vite preview --host 0.0.0.0",
    "serve": "bun src/server.ts"
  },
  "dependencies": {
    "@kv-designsystem/react": "^1.0.0-alpha.2",
    "@navikt/aksel-icons": "^8.14.0",
    "i18next": "^26.3.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "2.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
